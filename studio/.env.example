  # Studio + scripts тАФ copy to studio/.env.
  #
  # Used by `pnpm dev`, `pnpm build`, `pnpm deploy`, and the one-shot scripts
  # in `studio/scripts/` (seed, sync-jobs).

  # Required for Studio runtime + scripts.
  SANITY_STUDIO_PROJECT_ID=
  SANITY_STUDIO_DATASET=production

  # Where Presentation iframes the FE preview.                                                                                                                    
  SANITY_STUDIO_PREVIEW_URL=http://localhost:3000

  # Write-scoped token. Only needed when running:
  #   pnpm tsx scripts/seed.ts
  #   pnpm tsx scripts/sync-jobs.ts
  SANITY_API_WRITE_TOKEN=

  # Recruitee credentials тАФ only needed by scripts/sync-jobs.ts.
  RECRUITEE_API_URL=https://api.recruitee.com
  RECRUITEE_COMPANY_ID=
  RECRUITEE_API_TOKEN=